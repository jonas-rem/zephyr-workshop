config BUTTON_MOCK_COMPONENT
	bool "Button mock component for native_sim"
	depends on BOARD_NATIVE_SIM
	default y
	help
	  Enable button mock component that simulates physical button presses
	  using the GPIO emulator for native_sim builds.

module = BUTTON_MOCK_COMPONENT
module-str = button_mock
source "subsys/logging/Kconfig.template.log_config"

config BUTTON_MOCK_COMPONENT_INIT_PRIORITY
	int "Button mock component init priority"
	default 80
	help
	  System initialization priority for the button mock component.
	  This determines the order in which the button mock component is initialized.
