config LED_COMPONENT
	bool "LED component"
	default y
	help
	  Enable the LED component for visual feedback via board LEDs.

if LED_COMPONENT

module = LED_COMPONENT
module-str = LED
source "subsys/logging/Kconfig.template.log_config"

config LED_COMPONENT_THREAD_STACK_SIZE
	int "Thread stack size"
	default 1024

config LED_COMPONENT_THREAD_STACK_PRIO
	int "Thread stack priority"
	default -2

config LED_COMPONENT_SHELL
	bool "LED component shell commands"
	depends on SHELL
	default n
	help
	  Enable shell commands for controlling the LED component.
	  Provides commands to set LED states manually for testing.

config LED_COMPONENT_INIT_PRIORITY
	int "LED component init priority"
	default 90
	help
	  System initialization priority for the LED component.
	  This determines the order in which the LED component is initialized.

endif # LED_COMPONENT
