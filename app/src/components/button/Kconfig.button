config BUTTON_COMPONENT
	bool "Button component"
	default y
	help
	  Enable the button component for handling physical button inputs
	  and publishing button events via Zbus.

module = BUTTON_COMPONENT
module-str = BUTTON
source "subsys/logging/Kconfig.template.log_config"

config BUTTON_COMPONENT_INIT_PRIORITY
	int "Button component init priority"
	default 80
	help
	  System initialization priority for the button component.
	  This determines the order in which the button component is initialized.

config BUTTON_COMPONENT_SHELL
	bool "Button component shell commands"
	depends on SHELL
	default n
	help
	  Enable shell commands for the button component.
	  Provides commands to simulate button presses for testing.
