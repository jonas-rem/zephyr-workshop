config SYS_CTRL_COMPONENT
	bool "System control component"
	default y
	help
	  Enable the system control component that manages system state
	  and coordinates between other components via Zbus.

module = SYS_CTRL_COMPONENT
module-str = sys_ctrl
source "subsys/logging/Kconfig.template.log_config"

config SYS_CTRL_COMPONENT_INIT_PRIORITY
	int "System control component init priority"
	default 85
	help
	  System initialization priority for the system control component.
	  This determines the order in which the system control component is initialized.

config SYS_CTRL_COMPONENT_SHELL
	bool "System control component shell commands"
	depends on SHELL
	default n
	help
	  Enable shell commands for the system control component.
	  Provides commands to check system state and simulate events for testing.
