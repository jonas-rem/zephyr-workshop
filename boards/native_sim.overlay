/**
 * Workshop board overlay for native_sim.
 *
 * - HDC1010 sensor on emulated I2C bus (for sensor samples)
 * - Button sw0 alias (for app button module)
 * - Shell on uart1 (separate console for app)
 */

&i2c0 {
	ti_hdc: ti_hdc@43 {
		compatible = "ti,hdc";
		reg = <0x43>;
		status = "okay";
	};
};

/ {
	aliases {
		sw0 = &button0;
		led0 = &led0;
		led1 = &led1;
	};

	chosen {
		zephyr,shell-uart = &uart1;
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 1 GPIO_ACTIVE_LOW>;
			label = "User button";
		};
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
			label = "LED 0 (status)";
		};
		led1: led_1 {
			gpios = <&gpio0 3 GPIO_ACTIVE_LOW>;
			label = "LED 1 (events)";
		};
	};
};

&uart1 {
	status = "okay";
};
